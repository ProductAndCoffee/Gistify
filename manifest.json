{
  "manifest_version": 2,
  "name": "Gistify",
  "version": "1.0.0",
  "description": "Fast AI summaries and bookmarks for any page",
  "permissions": [
    "activeTab",
    "bookmarks",
    "downloads",
    "storage"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Gistify",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "config/providers.js",
      "background/background.js"
    ]
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}